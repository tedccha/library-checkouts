# Google OAuth
# Get these from https://console.cloud.google.com
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here

# NextAuth.js secret (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=your_secret_here
NEXTAUTH_URL=http://localhost:3000

# Library session cookies (from authenticated browser session)
# To get:
#   1. Sign in to https://catalog.chappaqualibrary.org
#   2. Open DevTools → Application → Cookies
#   3. Copy relevant cookies (PHPSESSID, aspendiscovery, etc.)
#   4. Paste below as semicolon-separated string, e.g.:
#      PHPSESSID=abc123def456; aspendiscovery=xyz789
LIBRARY_COOKIES=

# Allowed emails (comma-separated)
ALLOWED_EMAILS=tedcha@gmail.com,family_member@example.com
