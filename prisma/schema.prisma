generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Book {
  id        Int     @id @default(autoincrement())
  email     String
  title     String
  author    String
  dueDate   DateTime
  renewals  Int
  createdAt DateTime @default(now())

  @@index([email, createdAt])
}

model Session {
  sid       String    @id
  sess      Json
  expire    DateTime
}
